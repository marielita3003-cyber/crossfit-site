{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": ".*neveragainchallenge\\.com" }],
      "destination": "/never-again/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": ".*neveragainchallenge\\.com" }],
      "destination": "/never-again/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
